<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Seller Dashboard — ScanResi</title>
  <link rel="stylesheet" href="style.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { background: #f0f4f0; }
    [data-theme="dark"] body { background: #0d1b0d; }

    /* ══════════════════════════════
       LOGIN SCREEN
    ══════════════════════════════ */
    .login-screen {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      background: linear-gradient(160deg, #166534 0%, #16a34a 40%, #f0f4f0 100%);
    }
    [data-theme="dark"] .login-screen {
      background: linear-gradient(160deg, #0a1a0a 0%, #14532d 50%, #0d1b0d 100%);
    }
    .login-card {
      background: var(--bg-card);
      border-radius: 24px;
      padding: 36px 28px 32px;
      width: 100%;
      max-width: 380px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.18);
    }
    .login-logo {
      text-align: center;
      margin-bottom: 28px;
    }
    .login-logo .icon {
      width: 64px; height: 64px;
      background: linear-gradient(135deg, #166534, #22c55e);
      border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      font-size: 30px;
      margin: 0 auto 14px;
      box-shadow: 0 8px 24px rgba(22,163,74,0.3);
    }
    .login-logo h1 {
      font-size: 22px;
      font-weight: 800;
      color: var(--text-primary);
      letter-spacing: -0.02em;
    }
    .login-logo p {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }
    .login-form { display: flex; flex-direction: column; gap: 14px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-secondary);
    }
    .form-group .input-wrap { position: relative; }
    .form-group .input-wrap .icon {
      position: absolute; left: 12px; top: 50%;
      transform: translateY(-50%);
      font-size: 16px; pointer-events: none;
    }
    .form-group input {
      width: 100%;
      padding: 12px 14px 12px 40px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-family: var(--font);
      font-size: 14px;
      background: var(--bg);
      color: var(--text-primary);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-group input:focus {
      border-color: var(--green-500);
      box-shadow: 0 0 0 3px rgba(22,163,74,0.12);
      background: var(--bg-card);
    }
    .login-btn {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #166534, #16a34a);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-family: var(--font);
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 4px;
      transition: all 0.2s;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      box-shadow: 0 4px 16px rgba(22,163,74,0.3);
    }
    .login-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(22,163,74,0.4); }
    .login-btn:active { transform: translateY(0); }
    .login-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
    .login-error {
      background: #fee2e2;
      color: #991b1b;
      border-radius: 10px;
      padding: 11px 14px;
      font-size: 13px;
      font-weight: 500;
      display: none;
      align-items: center;
      gap: 8px;
    }
    [data-theme="dark"] .login-error { background: rgba(239,68,68,0.15); color: #fca5a5; }
    .login-error.show { display: flex; }
    .login-hint {
      text-align: center;
      margin-top: 16px;
      font-size: 12px;
      color: var(--text-muted);
    }
    .login-hint strong { color: var(--green-600); }

    /* ══════════════════════════════
       DASHBOARD (hidden until login)
    ══════════════════════════════ */
    .dashboard-screen { display: none; }
    .dashboard-screen.show { display: block; }

    /* HEADER */
    .mob-header {
      background: linear-gradient(135deg, #166534 0%, #16a34a 100%);
      padding: 20px 16px 56px;
      position: relative;
      overflow: hidden;
    }
    .mob-header::before {
      content: '';
      position: absolute; top: -30px; right: -30px;
      width: 140px; height: 140px;
      border-radius: 50%;
      background: rgba(255,255,255,0.07);
    }
    .mob-header::after {
      content: '';
      position: absolute; bottom: -20px; left: -20px;
      width: 100px; height: 100px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
    }
    .mob-header-top {
      display: flex; align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .mob-header-logo { display: flex; align-items: center; gap: 8px; }
    .mob-logo-icon {
      width: 32px; height: 32px;
      background: rgba(255,255,255,0.2);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }
    .mob-logo-text { color: #fff; font-size: 14px; font-weight: 700; }
    .mob-header-actions { display: flex; gap: 6px; }
    .mob-icon-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      background: rgba(255,255,255,0.15);
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 15px;
      position: relative;
    }
    .mob-header-name { color: rgba(255,255,255,0.75); font-size: 13px; margin-bottom: 4px; }
    .mob-seller-name { color: #fff; font-size: 22px; font-weight: 800; letter-spacing: -0.02em; }

    /* CONTENT */
    .mob-content {
      margin-top: -36px;
      padding: 0 12px 90px;
      position: relative;
      z-index: 1;
    }

    /* STATS */
    .mob-stat-wide {
      background: var(--bg-card);
      border-radius: var(--radius);
      padding: 16px 18px;
      box-shadow: var(--shadow);
      margin-bottom: 12px;
      border: 1px solid var(--border-light);
      display: flex; align-items: center; justify-content: space-between;
    }
    .mob-stat-wide .wlabel { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); }
    .mob-stat-wide .wvalue { font-size: 18px; font-weight: 800; color: var(--text-primary); }
    .mob-stat-wide .wsub { font-size: 11px; color: var(--green-600); font-weight: 600; }

    .mob-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
    .mob-stat {
      background: var(--bg-card);
      border-radius: var(--radius);
      padding: 16px 14px;
      box-shadow: var(--shadow);
      border: 1px solid var(--border-light);
    }
    .mob-stat-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 6px; }
    .mob-stat-value { font-size: 20px; font-weight: 800; color: var(--text-primary); letter-spacing: -0.02em; }
    .mob-stat-sub { font-size: 10px; color: var(--text-muted); margin-top: 4px; }
    .mob-stat.lunas .mob-stat-value { color: var(--green-600); }
    .mob-stat.belum .mob-stat-value { color: #d97706; }

    /* SECTION */
    .mob-section {
      background: var(--bg-card);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 12px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-light);
    }
    .mob-section canvas { height: 160px !important; }

    /* RESI LIST */
    .resi-item {
      display: flex; align-items: center;
      padding: 12px 0;
      border-top: 1px solid var(--border-light);
      gap: 12px;
    }
    .resi-item:first-of-type { border-top: none; }
    .resi-date-badge {
      width: 40px; height: 40px;
      border-radius: 10px;
      background: var(--green-50);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      flex-shrink: 0;
      font-size: 10px; font-weight: 700;
      color: var(--green-700); line-height: 1.2;
    }
    [data-theme="dark"] .resi-date-badge { background: rgba(22,163,74,0.15); }
    .resi-info { flex: 1; min-width: 0; }
    .resi-number { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--text-primary); }
    .resi-meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

    /* FILTER */
    .mob-filter { display: flex; gap: 8px; margin-bottom: 12px; }

    /* TABS */
    .section-tabs { display: flex; gap: 6px; margin-bottom: 14px; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
    .section-tabs::-webkit-scrollbar { display: none; }
    .tab-pill {
      flex-shrink: 0; padding: 6px 14px;
      border-radius: 99px; font-size: 12px; font-weight: 600;
      cursor: pointer; border: 1.5px solid var(--border);
      background: var(--bg-card); color: var(--text-secondary);
      transition: all 0.15s;
    }
    .tab-pill.active { background: var(--green-600); border-color: var(--green-600); color: #fff; }

    /* BOTTOM NAV */
    .mob-bottom-nav {
      position: fixed; bottom: 0; left: 0; right: 0;
      background: var(--bg-card);
      border-top: 1px solid var(--border);
      display: flex;
      padding: 8px 0 max(8px, env(safe-area-inset-bottom));
      z-index: 100;
    }
    .mob-nav-item {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 3px; cursor: pointer; color: var(--text-muted);
      font-size: 10px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.04em;
      padding: 4px 0; transition: color 0.15s;
    }
    .mob-nav-item.active { color: var(--green-600); }
    .mob-nav-item .nav-icon { font-size: 20px; }

    /* EMPTY */
    .mob-empty { text-align: center; padding: 32px 16px; color: var(--text-muted); }
    .mob-empty .icon { font-size: 36px; margin-bottom: 8px; }

    /* LOGOUT CONFIRM */
    .logout-btn {
      width: 100%;
      padding: 13px;
      background: #fee2e2;
      color: #991b1b;
      border: none;
      border-radius: 10px;
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 8px;
      transition: all 0.15s;
    }
    .logout-btn:hover { background: #fecaca; }

    /* SESSION INFO */
    .session-card {
      background: var(--green-50);
      border: 1px solid var(--green-200);
      border-radius: 10px;
      padding: 12px 14px;
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 12px;
    }
    [data-theme="dark"] .session-card { background: rgba(22,163,74,0.1); border-color: rgba(22,163,74,0.25); }
    .session-avatar {
      width: 36px; height: 36px;
      background: var(--green-600);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 800; font-size: 14px;
      flex-shrink: 0;
    }
    .session-info .sname { font-size: 13px; font-weight: 700; color: var(--text-primary); }
    .session-info .srole { font-size: 11px; color: var(--green-700); font-weight: 600; }
    [data-theme="dark"] .session-info .srole { color: var(--green-400); }

    /* LOADING SCREEN */
    .mob-loading {
      position: fixed; inset: 0;
      background: var(--bg);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      z-index: 999;
    }
    .mob-loading p { color: var(--text-muted); font-size: 13px; margin-top: 12px; }
  </style>
</head>
<body>

<!-- LOADING SCREEN -->
<div class="mob-loading" id="loadingScreen">
  <div style="font-size:48px;margin-bottom:16px">📦</div>
  <div class="spinner" style="width:32px;height:32px;border-width:3px"></div>
  <p id="loadingText">Memuat…</p>
</div>

<!-- ══════════════════════════════════════
     LOGIN SCREEN
══════════════════════════════════════ -->
<div class="login-screen" id="loginScreen" style="display:none">
  <div class="login-card">
    <div class="login-logo">
      <div class="icon">📦</div>
      <h1>ScanResi Seller</h1>
      <p>Masuk untuk melihat dashboard Anda</p>
    </div>

    <div class="login-form">
      <div class="login-error" id="loginError">
        <span>⚠️</span>
        <span id="loginErrorMsg">Nama atau nomor WA salah</span>
      </div>

      <div class="form-group">
        <label>Nama Seller</label>
        <div class="input-wrap">
          <span class="icon">👤</span>
          <input type="text" id="inputNama" placeholder="Contoh: LUNISCA2026-01"
            autocomplete="username" autocapitalize="characters"
            onkeydown="if(event.key==='Enter') focusWa()" />
        </div>
      </div>

      <div class="form-group">
        <label>Nomor WhatsApp (Password)</label>
        <div class="input-wrap">
          <span class="icon">📱</span>
          <input type="tel" id="inputWa" placeholder="Contoh: 08123456789"
            autocomplete="current-password"
            onkeydown="if(event.key==='Enter') doLogin()" />
        </div>
      </div>

      <button class="login-btn" id="loginBtn" onclick="doLogin()">
        <span>🔐</span> Masuk
      </button>
    </div>

    <div class="login-hint">
      Username: <strong>Nama seller</strong> &nbsp;·&nbsp;
      Password: <strong>Nomor WA</strong>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     DASHBOARD SCREEN
══════════════════════════════════════ -->
<div class="dashboard-screen" id="dashboardScreen">

  <!-- HEADER -->
  <div class="mob-header">
    <div class="mob-header-top">
      <div class="mob-header-logo">
        <div class="mob-logo-icon">📦</div>
        <span class="mob-logo-text">ScanResi</span>
      </div>
      <div class="mob-header-actions">
        <button class="mob-icon-btn" id="darkModeToggle" title="Dark Mode">🌙</button>
        <button class="mob-icon-btn" onclick="refreshData()" title="Refresh">🔄</button>
        <button class="mob-icon-btn" onclick="doLogout()" title="Keluar">🚪</button>
      </div>
    </div>
    <div class="mob-header-name">Selamat datang,</div>
    <div class="mob-seller-name" id="headerSellerName">—</div>
  </div>

  <!-- CONTENT -->
  <div class="mob-content">

    <!-- SESSION INFO -->
    <div class="session-card">
      <div class="session-avatar" id="sessionAvatar">?</div>
      <div class="session-info">
        <div class="sname" id="sessionName">—</div>
        <div class="srole">✅ Login sebagai Seller</div>
      </div>
    </div>

    <!-- WIDE STAT -->
    <div class="mob-stat-wide">
      <div>
        <div class="wlabel">Total Penjualan</div>
        <div class="wvalue" id="wTotalPenjualan">Rp —</div>
        <div class="wsub" id="wResiCount">— resi total</div>
      </div>
      <div style="font-size:36px">💰</div>
    </div>

    <!-- STATS GRID -->
    <div class="mob-stats">
      <div class="mob-stat lunas">
        <div class="mob-stat-label">Total Resi</div>
        <div class="mob-stat-value" id="mTotalResi">—</div>
        <div class="mob-stat-sub">semua transaksi</div>
      </div>
      <div class="mob-stat belum">
        <div class="mob-stat-label">Belum Bayar</div>
        <div class="mob-stat-value" id="mBelumCount">—</div>
        <div class="mob-stat-sub" id="mBelumNominal">Rp —</div>
      </div>
      <div class="mob-stat lunas">
        <div class="mob-stat-label">Sudah Dibayar</div>
        <div class="mob-stat-value" id="mLunasCount">—</div>
        <div class="mob-stat-sub" id="mLunasNominal">Rp —</div>
      </div>
      <div class="mob-stat">
        <div class="mob-stat-label">Hari Ini</div>
        <div class="mob-stat-value" id="mHariIni">—</div>
        <div class="mob-stat-sub">resi baru</div>
      </div>
    </div>

    <!-- CHART -->
    <div class="mob-section">
      <div class="section-title">Penjualan Harian</div>
      <div class="chart-container"><canvas id="chartHarian"></canvas></div>
    </div>

    <!-- RESI LIST -->
    <div class="mob-section">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <div class="section-title" style="margin-bottom:0">Data Resi</div>
        <button class="btn btn-outline btn-sm" onclick="doExport()">📥 Export</button>
      </div>

      <div class="section-tabs">
        <div class="tab-pill active" onclick="setTab('semua', this)">Semua</div>
        <div class="tab-pill" onclick="setTab('LUNAS', this)">LUNAS</div>
        <div class="tab-pill" onclick="setTab('BELUM', this)">BELUM</div>
      </div>

      <div class="mob-filter">
        <div style="position:relative;flex:1">
          <span style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:12px">🔍</span>
          <input type="text" class="input" id="resiSearch"
            placeholder="Cari nomor resi…"
            oninput="renderResiList()"
            style="padding-left:30px" />
        </div>
      </div>

      <div id="resiListContainer">
        <div class="mob-empty"><div class="icon">📭</div><p>Memuat data…</p></div>
      </div>

      <div id="mobPagination"
        style="display:flex;align-items:center;justify-content:center;gap:6px;margin-top:12px">
      </div>
    </div>

    <!-- LOGOUT -->
    <div class="mob-section">
      <div class="section-title">Akun</div>
      <div style="font-size:13px;color:var(--text-secondary);margin-bottom:8px">
        Login sebagai <strong id="logoutSellerName">—</strong>
      </div>
      <button class="logout-btn" onclick="doLogout()">🚪 Keluar dari Akun</button>
    </div>

  </div>

  <!-- BOTTOM NAV -->
  <nav class="mob-bottom-nav">
    <div class="mob-nav-item active">
      <div class="nav-icon">📊</div>
      <span>Dashboard</span>
    </div>
    <div class="mob-nav-item">
      <div class="nav-icon">📋</div>
      <span>Resi</span>
    </div>
    <div class="mob-nav-item">
      <div class="nav-icon">💰</div>
      <span>Bayar</span>
    </div>
    <div class="mob-nav-item" onclick="doLogout()">
      <div class="nav-icon">🚪</div>
      <span>Keluar</span>
    </div>
  </nav>
</div>

<!-- LOGOUT MODAL -->
<div class="modal-overlay" id="logoutModal">
  <div class="modal">
    <div class="modal-icon">🚪</div>
    <h3>Keluar?</h3>
    <p>Anda akan keluar dari akun seller ini.</p>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal('logoutModal')">Batal</button>
      <button class="btn btn-danger" onclick="confirmLogout()">Ya, Keluar</button>
    </div>
  </div>
</div>

<script src="api.js"></script>
<script src="dashboard.js"></script>
<script>
  let sellerResi    = [];
  let currentSeller = "";
  let activeTab     = "semua";
  let mobPaginator;
  const MOB_PAGE_SIZE = 10;
  const SESSION_KEY   = "scanresi_seller";

  // ── BOOT ─────────────────────────────────────────────────
  function boot() {
    initDarkMode();

    // Cek session tersimpan
    const saved = sessionStorage.getItem(SESSION_KEY);
    if (saved) {
      const sess = JSON.parse(saved);
      // Session valid selama tab masih buka (sessionStorage)
      startDashboard(sess.seller);
    } else {
      showLogin();
    }
  }

  function showLogin() {
    document.getElementById("loadingScreen").style.display  = "none";
    document.getElementById("loginScreen").style.display    = "flex";
    document.getElementById("dashboardScreen").classList.remove("show");
    setTimeout(() => document.getElementById("inputNama").focus(), 100);
  }

  function showDashboard(sellerName) {
    document.getElementById("loadingScreen").style.display  = "none";
    document.getElementById("loginScreen").style.display    = "none";
    document.getElementById("dashboardScreen").classList.add("show");
  }

  function focusWa() {
    document.getElementById("inputWa").focus();
  }

  // ── LOGIN ────────────────────────────────────────────────
  async function doLogin() {
    const nama = document.getElementById("inputNama").value.trim();
    const wa   = document.getElementById("inputWa").value.trim();
    const btn  = document.getElementById("loginBtn");
    const err  = document.getElementById("loginError");

    err.classList.remove("show");

    if (!nama || !wa) {
      showLoginError("Nama dan nomor WA wajib diisi");
      return;
    }

    btn.disabled = true;
    btn.innerHTML = `<div class="spinner" style="border-color:rgba(255,255,255,0.3);border-top-color:#fff"></div> Memeriksa…`;

    try {
      let result;

      if (USE_MOCK) {
        // Demo: cek dari MOCK_SELLERS, password = "08123456789" untuk semua
        const found = MOCK_SELLERS.find(s => s.toLowerCase() === nama.toLowerCase());
        if (found && wa === "08123456789") {
          result = { status: "ok", seller: found };
        } else {
          result = { status: "gagal", pesan: "Nama atau nomor WA salah\n(Demo: password = 08123456789)" };
        }
      } else {
        result = await apiFetch({ action: "login", nama, wa });
      }

      if (result.status === "ok") {
        // Simpan session
        sessionStorage.setItem(SESSION_KEY, JSON.stringify({ seller: result.seller }));
        startDashboard(result.seller);
      } else {
        showLoginError(result.pesan || "Nama atau nomor WA salah");
      }
    } catch (e) {
      showLoginError("Gagal terhubung ke server. Cek koneksi internet.");
    } finally {
      btn.disabled = false;
      btn.innerHTML = `<span>🔐</span> Masuk`;
    }
  }

  function showLoginError(msg) {
    document.getElementById("loginErrorMsg").textContent = msg;
    document.getElementById("loginError").classList.add("show");
    document.getElementById("inputNama").focus();
  }

  // ── START DASHBOARD ──────────────────────────────────────
  async function startDashboard(sellerName) {
    currentSeller = sellerName;

    // Update UI nama
    document.getElementById("headerSellerName").textContent = sellerName;
    document.getElementById("sessionName").textContent      = sellerName;
    document.getElementById("sessionAvatar").textContent    = sellerName.charAt(0).toUpperCase();
    document.getElementById("logoutSellerName").textContent = sellerName;

    showDashboard(sellerName);

    document.getElementById("loadingText").textContent = "Memuat data " + sellerName + "…";
    document.getElementById("loadingScreen").style.display = "flex";

    try {
      sellerResi = await loadResi({ seller: sellerName });
    } catch (e) {
      sellerResi = MOCK_RESI.filter(r => r.seller === sellerName);
      showToast("Menggunakan data demo", "warn");
    } finally {
      document.getElementById("loadingScreen").style.display = "none";
    }

    renderStats(sellerResi);
    renderChart(sellerResi);
    renderResiList();
  }

  async function refreshData() {
    if (!currentSeller) return;
    document.getElementById("loadingScreen").style.display = "flex";
    document.getElementById("loadingText").textContent = "Memperbarui data…";
    await startDashboard(currentSeller);
    showToast("Data diperbarui ✅");
  }

  // ── LOGOUT ───────────────────────────────────────────────
  function doLogout() {
    openModal("logoutModal");
  }

  function confirmLogout() {
    closeModal("logoutModal");
    sessionStorage.removeItem(SESSION_KEY);
    sellerResi    = [];
    currentSeller = "";
    // Reset form
    document.getElementById("inputNama").value = "";
    document.getElementById("inputWa").value   = "";
    document.getElementById("loginError").classList.remove("show");
    showLogin();
  }

  // ── STATS ────────────────────────────────────────────────
  function renderStats(data) {
    const total  = data.reduce((s, r) => s + Number(r.total || r.harga || 0), 0);
    const lunas  = data.filter(r => r.status === "LUNAS");
    const belum  = data.filter(r => r.status === "BELUM");
    const today  = new Date().toLocaleDateString("id-ID");
    const hariIni = data.filter(r => new Date(r.tanggal).toLocaleDateString("id-ID") === today).length;

    document.getElementById("wTotalPenjualan").textContent = formatRupiah(total);
    document.getElementById("wResiCount").textContent      = data.length + " resi total";
    document.getElementById("mTotalResi").textContent      = data.length;
    document.getElementById("mLunasCount").textContent     = lunas.length;
    document.getElementById("mLunasNominal").textContent   = formatRupiah(lunas.reduce((s,r)=>s+Number(r.total||r.harga||0),0));
    document.getElementById("mBelumCount").textContent     = belum.length;
    document.getElementById("mBelumNominal").textContent   = formatRupiah(belum.reduce((s,r)=>s+Number(r.total||r.harga||0),0));
    document.getElementById("mHariIni").textContent        = hariIni;
  }

  // ── CHART ────────────────────────────────────────────────
  function renderChart(data) {
    const harian = computePenjualanHarian(data, 7);
    const ctx    = document.getElementById("chartHarian")?.getContext("2d");
    const grad   = ctx?.createLinearGradient(0,0,0,160);
    if (grad) {
      grad.addColorStop(0, "rgba(22,163,74,0.3)");
      grad.addColorStop(1, "rgba(22,163,74,0)");
    }
    makeLineChart("chartHarian",
      harian.map(x => x.label),
      [{
        label: "Penjualan",
        data: harian.map(x => x.total),
        borderColor: "#16a34a",
        backgroundColor: grad || "rgba(22,163,74,0.15)",
        fill: true, tension: 0.4,
        pointBackgroundColor: "#fff",
        pointBorderColor: "#16a34a",
        pointBorderWidth: 2,
        pointRadius: 4, pointHoverRadius: 6,
      }]
    );
  }

  // ── RESI LIST ────────────────────────────────────────────
  function setTab(tab, el) {
    activeTab = tab;
    document.querySelectorAll(".tab-pill").forEach(t => t.classList.remove("active"));
    el.classList.add("active");
    renderResiList();
  }

  function renderResiList() {
    const search = document.getElementById("resiSearch").value.toLowerCase();
    let data = sellerResi;
    if (activeTab !== "semua") data = data.filter(r => r.status === activeTab);
    if (search) data = data.filter(r =>
      r.nomor_resi?.toLowerCase().includes(search) ||
      r.produk?.toLowerCase().includes(search)
    );

    mobPaginator = new Paginator(data, MOB_PAGE_SIZE);
    renderResiPage();
  }

  function renderResiPage() {
    const data      = mobPaginator.currentData;
    const container = document.getElementById("resiListContainer");

    if (!data.length) {
      container.innerHTML = `<div class="mob-empty"><div class="icon">📭</div><p>Tidak ada data</p></div>`;
      document.getElementById("mobPagination").innerHTML = "";
      return;
    }

    container.innerHTML = data.map(r => {
      const d   = new Date(r.tanggal);
      const day = isNaN(d) ? "" : d.getDate();
      const mon = isNaN(d) ? "" : d.toLocaleDateString("id-ID", { month: "short" });
      return `
        <div class="resi-item">
          <div class="resi-date-badge"><div>${day}</div><div>${mon}</div></div>
          <div class="resi-info">
            <div class="resi-number">${r.nomor_resi}</div>
            <div class="resi-meta">${r.produk} · ${formatRupiah(r.total || r.harga)}</div>
          </div>
          <span class="badge badge-${r.status === 'LUNAS' ? 'lunas' : 'belum'}">${r.status}</span>
        </div>`;
    }).join("");

    const total = mobPaginator.totalPages;
    const cur   = mobPaginator.currentPage;
    const pag   = document.getElementById("mobPagination");
    if (total <= 1) { pag.innerHTML = ""; return; }
    pag.innerHTML = `
      <button class="page-btn" onclick="mobGoToPage(${cur-1})" ${cur===1?"disabled":""}>‹</button>
      <span style="font-size:12px;color:var(--text-muted);padding:0 8px">${cur} / ${total}</span>
      <button class="page-btn" onclick="mobGoToPage(${cur+1})" ${cur===total?"disabled":""}>›</button>`;
  }

  function mobGoToPage(p) {
    mobPaginator.setPage(p);
    renderResiPage();
    window.scrollTo({ top: 400, behavior: "smooth" });
  }

  // ── EXPORT ───────────────────────────────────────────────
  function doExport() {
    if (!sellerResi.length) { showToast("Tidak ada data", "warn"); return; }
    exportToCSV(sellerResi, currentSeller + "-resi.csv");
    showToast("Data berhasil diexport");
  }

  // ── START ────────────────────────────────────────────────
  boot();
</script>
</body>
</html>
